{
  "name": "sparaviewer",
  "version": "1.0.0",
  "description": "S参数后处理软件 - 支持Touchstone格式文件解析、TDR/TDT计算、Smith圆图等功能",
  "main": "src/main.js",
  "scripts": {
    "start": "npx electron .",
    "dev": "npx electron . --dev",
    "build": "npx electron-builder",
    "build:win": "npx electron-builder --win",
    "pack": "npx electron-builder --dir",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["s-parameter", "touchstone", "rf", "microwave", "smith-chart", "tdr"],
  "author": "SParaViewer Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "plotly.js-dist-min": "^2.28.0"
  },
  "build": {
    "appId": "com.sparaviewer.app",
    "productName": "SParaViewer",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SParaViewer",
      "installerIcon": "assets/icon.svg",
      "uninstallerIcon": "assets/icon.svg",
      "installerHeaderIcon": "assets/icon.svg",
      "license": "LICENSE"
    }
  }
}
